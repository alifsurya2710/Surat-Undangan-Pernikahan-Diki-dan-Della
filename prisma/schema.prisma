generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Wish {
  id        String   @id @default(cuid())
  name      String
  message   String   @db.Text
  ownerId   String?  // Untuk menandai ucapan miliknya di browser
  createdAt DateTime @default(now())
}
